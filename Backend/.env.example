# Backend environment variables
DEBUG=True
ALLOWED_HOSTS=*

# Security keys (use long random strings in real environments)
SECRET_KEY=django-insecure-brightskill-development-key-please-change-this-1234567890
JWT_SIGNING_KEY=brightskill-jwt-signing-key-minimum-32-bytes-change-this-now-123456

# PostgreSQL
DB_NAME=brightskill
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
INLINE_BOOK_RECOMMENDATIONS=False
